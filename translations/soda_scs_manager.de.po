#: src/Form/KeycloakUserRegistrationForm.php:183
msgid "I agree to the <a href=\"/terms-of-service\" target=\"_blank\">terms of service</a>"
msgstr "Ich stimme den <a href=\"/terms-of-service\" target=\"_blank\">Nutzungsbedingungen</a> zu."

#: src/Form/KeycloakUserRegistrationForm.php:189
msgid "I agree to the <a href=\"/imprint-privacy-policy\" target=\"_blank\">privacy policy</a>"
msgstr "Ich stimme der <a href=\"/imprint-privacy-policy\" target=\"_blank\">Datenschutzerklärung</a> zu."

#: src/Form/KeycloakUserRegistrationForm.php:199
msgid "Register"
msgstr "Registrieren"

#: src/Form/KeycloakUserRegistrationForm.php:196
msgid "The email address %mail is not valid."
msgstr "Die E-Mail-Adresse %mail ist nicht gültig."

#: src/Form/KeycloakUserRegistrationForm.php:207
msgid "There is already a pending registration for this email address."
