    '#weight' => 0,
  ];

  $form['soda_scs_nextcloud']['wrapper']['fallback_hint'] = [
    '#type' => 'markup',
    '#markup' => '<p class="scs-manager--nextcloud-connect-fallback-hint" style="margin-top:0.5em;font-size:0.9em;color:#666;">' . \Drupal::translation()->translate('If SSO does not work, connect via app password:') . '</p>',
    '#weight' => 1,
  ];

  $form['soda_scs_nextcloud']['wrapper']['connect'] = [
    '#type' => 'button',
    '#value' => \Drupal::translation()->translate('Connect via app password'),
    '#attributes' => [
      'class' => ['scs-manager--nextcloud-connect-btn', 'button'],
      'type' => 'button',
    ],
    '#weight' => 2,
  ];

  $form['soda_scs_nextcloud']['status_check'] = [
    '#type' => 'container',
    '#attributes' => [
      'class' => ['scs-manager--nextcloud-status-check'],
      'style' => 'margin-top: 1rem; padding-top: 1rem; border-top: 1px solid #ddd;',
    ],
    '#weight' => 10,
  ];

  $form['soda_scs_nextcloud']['status_check']['line'] = [
    '#type' => 'markup',
    '#markup' => '<p class="scs-manager--nextcloud-status-check-line"><span class="scs-manager--nextcloud-status-check-label">' . \Drupal::translation()->translate('Status') . ': </span><span class="scs-manager--nextcloud-status-check-result" data-status="unknown">' . \Drupal::translation()->translate('Checking...') . '</span></p>',
    '#weight' => 0,
  ];

  $form['soda_scs_nextcloud']['status_check']['verify'] = [
    '#type' => 'button',
    '#value' => \Drupal::translation()->translate('Verify connection'),
    '#attributes' => [
      'class' => ['scs-manager--nextcloud-verify-btn', 'button', 'button--small'],
      'type' => 'button',
    ],
    '#weight' => 1,
  ];
}

/**
 * Implements hook_form_alter() for user_login_form.
 *
 * Sets default destination to redirect users to the SODa SCS Manager dashboard after login.
 */
function soda_scs_manager_form_user_login_form_alter(&$form, &$form_state, $form_id) {
  // Get the current request.
  $request = \Drupal::request();

  // Only set destination if there's no existing destination and not during AJAX requests.
  if (!$request->query->has('destination') && !$request->isXmlHttpRequest()) {
    // Set destination via URL query parameter.
    $destination = Url::fromRoute('soda_scs_manager.dashboard')->toString();
    $destinationUrl = Url::fromRoute('user.login', [], ['query' => ['destination' => $destination]]);
    $form['#action'] = $destinationUrl->toString();
  }
}

/**
 * Implements hook_user_login().
 *
 * Note: Redirect is handled via destination field in hook_form_alter().
 */
function soda_scs_manager_user_login(UserInterface $account) {
  // Redirect logic handled via destination parameter in login form.
}

/**
 * Implements hook_file_download().
 *
 * Controls access to private snapshot files.
 */
function soda_scs_manager_file_download($uri) {
  // Only handle private files in the snapshots directory.
  $streamWrapperManager = \Drupal::service('stream_wrapper_manager');
  $scheme = $streamWrapperManager->getScheme($uri);
  if ($scheme !== 'private') {
    return NULL;
  }
  $target = $streamWrapperManager->getTarget($uri);
  $snapshotTargetPrefix = SodaScsSnapshotHelpers::SNAPSHOT_PRIVATE_URI_SUBPATH . '/';
  if (!\str_starts_with($target, $snapshotTargetPrefix)) {
    return NULL;
  }

  $account = \Drupal::currentUser();

  // Admins can always download.
  if ($account->hasPermission('soda scs manager admin')) {
    $mimeType = 'application/octet-stream';
    if ($file = \Drupal::service('file.repository')->loadByUri($uri)) {
      $mimeType = $file->getMimeType() ?: $mimeType;
    }
    return [
      'Content-Type' => $mimeType,
      'Content-Disposition' => 'attachment; filename="' . basename($uri) . '"',
    ];
  }

  // Require the generic permission first.
  if (!$account->hasPermission('view soda scs snapshot')) {
    return -1;
  }

  // Resolve the file entity by URI.
  /** @var \Drupal\file\FileInterface|null $file */
  $fileRepository = \Drupal::service('file.repository');
  $normalizedUri = $scheme . '://' . ltrim($target, '/');
  $alternativeUri = $scheme . ':///' . ltrim($target, '/');
  $file = $fileRepository->loadByUri($uri)
    ?: $fileRepository->loadByUri($normalizedUri)
    ?: $fileRepository->loadByUri($alternativeUri);
  if (!$file) {
    // Unknown file in private snapshots path. Deny to avoid leakage.
    return -1;
  }

  $fid = (int) $file->id();

  // Find snapshots that reference this file (either main file or signature).
  $storage = \Drupal::entityTypeManager()->getStorage('soda_scs_snapshot');
  $query = $storage->getQuery()
    ->accessCheck(FALSE);

  $or = $query->orConditionGroup()
    ->condition('file.target_id', $fid)
    ->condition('checksumFile.target_id', $fid);

  // Enforce owner-based access.
  $query
    ->condition($or)
    ->condition('owner', (int) $account->id());

  $ids = $query->execute();

  if (empty($ids)) {
    // No snapshot owned by the user references this file.
    return -1;
  }

  // Optionally, double-check access on any referencing snapshot.
  $snapshots = $storage->loadMultiple($ids);
  foreach ($snapshots as $snapshot) {
    /** @var \Drupal\soda_scs_manager\Entity\SodaScsSnapshot $snapshot */
    if ((int) $snapshot->get('owner')->target_id === (int) $account->id()) {
      $mimeType = $file->getMimeType() ?: 'application/octet-stream';
      return [
        'Content-Type' => $mimeType,
        'Content-Disposition' => 'attachment; filename="' . basename($uri) . '"',
      ];
    }
  }

  return -1;
}

/**
 * Create default applications for new user.
 */
function _soda_scs_manager_create_default_applications_for_user(UserInterface $user) {
  // Get the default project for the user.
  $projects = (array) SodaScsProject::loadByOwner($user->id());

  if (empty($projects) || count($projects) > 1) {
    $messenger = \Drupal::messenger();
    $messenger->addError(\Drupal::translation()->translate('Failed to create default applications for user: @username. No default project found.', ['@username' => $user->getDisplayName()]));
    $logger = \Drupal::logger('soda_scs_manager');
    $logger->error('Failed to create default applications for user: @username. No default project found.', ['@username' => $user->getDisplayName()]);
    return;
  }

  // Get the default project. Should only be one.
  /** @var \Drupal\soda_scs_manager\Entity\SodaScsProject $project */
  $project = reset($projects);

  _soda_scs_manager_create_default_nextcloud_for_user($user);
  _soda_scs_manager_create_default_jupyter_for_user($user);
  _soda_scs_manager_create_default_webprotege_for_user($user);
}

/**
 * Create default project for new user.
 *
 * The groupId is now automatically set in the insert hook to avoid double save.
 */
function _soda_scs_manager_create_default_project_for_user(UserInterface $user) {

  $project = SodaScsProject::create([
    'bundle' => 'default',
    'label' => $user->getDisplayName() . ' default project',
    'owner' => $user->id(),
  ]);

  $project->save();

  /** @var \Drupal\soda_scs_manager\Helpers\SodaScsProjectHelpers $projectHelpers */
  $projectHelpers = \Drupal::service('soda_scs_manager.project.helpers');
  $kcToken = $projectHelpers->getKeycloakToken();
  if (!$kcToken) {
    return;
  }

  $createProjectGroupResult = $projectHelpers->createProjectGroup($project);
  if (!$createProjectGroupResult->success) {
    return;
  }
  $keycloakUuid = $createProjectGroupResult->data['keycloakGroupData']->uuid;

  if (is_string($keycloakUuid) && $keycloakUuid !== '') {
    $project->set('keycloakUuid', $keycloakUuid);
  }

  $project->save();

  // Set the default project for the user.
  $user->set('default_project', $project->id());
  $user->save();

  // Sync user and keycloak groups.
  $syncKeycloakGroupMembersResult = \Drupal::service('soda_scs_manager.project.helpers')->syncKeycloakGroupMembers($project);
  if (!$syncKeycloakGroupMembersResult->success) {
    $messenger = \Drupal::messenger();
    $messenger->addError(\Drupal::translation()->translate('Failed to sync user and keycloak groups for user: @username. @error', [
      '@username' => $user->getDisplayName(),
      '@error' => $syncKeycloakGroupMembersResult->error,
    ]));
    $logger = \Drupal::logger('soda_scs_manager');
    $logger->error('Failed to sync user and keycloak groups for user: @username. @error', [
      '@username' => $user->getDisplayName(),
      '@error' => $syncKeycloakGroupMembersResult->error,
    ]);
  }
  else {
    $messenger = \Drupal::messenger();
    $messenger->addMessage(\Drupal::translation()->translate('Successfully synced user and keycloak groups for user: @username', ['@username' => $user->getDisplayName()]));
    $logger = \Drupal::logger('soda_scs_manager');
    $logger->notice('Successfully synced user and keycloak groups for user: @username', ['@username' => $user->getDisplayName()]);
  }

  // Sync MariaDB access for project members (phpMyAdmin SSO).
  \Drupal::service('soda_scs_manager.project_db_access.helpers')->syncProjectMembersDbAccess($project);
}

/**
 * Create default nextcloud for new user.
 */
function _soda_scs_manager_create_default_nextcloud_for_user(UserInterface $user) {
  // Load the bundle info for the nextcloud stack.
  $bundleinfo = \Drupal::service('entity_type.bundle.info')->getBundleInfo('soda_scs_stack')['soda_scs_nextcloud_stack'];

  if (!$bundleinfo) {
    throw new \Exception('Nextcloud stack bundle info not found');
  }

  $nextcloud = SodaScsStack::create([
    'bundle' => 'soda_scs_nextcloud_stack',
    'description' => $bundleinfo['description'],
    'imageUrl' => $bundleinfo['imageUrl'],
    'label' => $user->getDisplayName() . '\'s nextcloud',
    'machineName' => 'nextcloud-' . $user->getDisplayName() . '-default',
    'owner' => $user->id(),
  ]);

  \Drupal::service('soda_scs_manager.stack.actions')->createStack($nextcloud);
}

/**
 * Create default jupyter for new user.
 */
function _soda_scs_manager_create_default_jupyter_for_user(UserInterface $user) {
  // Load the bundle info for the jupyter stack.
  $bundleinfo = \Drupal::service('entity_type.bundle.info')->getBundleInfo('soda_scs_stack')['soda_scs_jupyter_stack'];

  if (!$bundleinfo) {
    throw new \Exception('Jupyter stack bundle info not found');
  }

  $jupyter = SodaScsStack::create([
    'bundle' => 'soda_scs_jupyter_stack',
    'description' => $bundleinfo['description'],
    'imageUrl' => $bundleinfo['imageUrl'],
    'label' => $user->getDisplayName() . '\'s jupyter',
    'machineName' => 'jupyter-' . $user->getDisplayName() . '-default',
    'owner' => $user->id(),
  ]);

  \Drupal::service('soda_scs_manager.stack.actions')->createStack($jupyter);
}

/**
 * Create default webprotege for new user.
 *
 * Webprotege is created but not added to any project (not part of default project).
 */
function _soda_scs_manager_create_default_webprotege_for_user(UserInterface $user) {
  // Load the bundle info for the webprotege stack.
  $bundleinfo = \Drupal::service('entity_type.bundle.info')->getBundleInfo('soda_scs_component')['soda_scs_webprotege_component'];

  if (!$bundleinfo) {
    throw new \Exception('Webprotege stack bundle info not found');
  }

  $webprotege = SodaScsComponent::create([
    'bundle' => 'soda_scs_webprotege_component',
    'description' => $bundleinfo['description'],
    'imageUrl' => $bundleinfo['imageUrl'],
    'label' => $user->getDisplayName() . '\'s webprotege',
    'machineName' => 'webprotege-' . $user->getDisplayName() . '-default',
    'owner' => $user->id(),
  ]);

  \Drupal::service('soda_scs_manager.component.actions')->createComponent($webprotege);
}

/**
 * Ensure the scs_user role exists and has the required permissions.
 */
function _soda_scs_manager_ensure_scs_user_role() {
  // Get the role storage.
  $role_storage = \Drupal::entityTypeManager()->getStorage('user_role');

  // Create the custom role if it doesn't exist.
  if (!$role_storage->load('scs_user')) {
    $role = $role_storage->create(['id' => 'scs_user', 'label' => 'scs_user']);
    $role->save();
  }

  // Assign the required permissions to the custom role.
  // @todo Check if all are needed, because we manage access owner based at many places.
  $permissions = [
    'create soda scs component',
    'create soda scs project',
    'create soda scs service key',
    'create soda scs snapshot',
    'create soda scs stack',
    'delete soda scs component',
    'delete soda scs project',
    'delete soda scs service key',
    'delete soda scs snapshot',
    'delete soda scs stack',
    'soda scs manager user',
    'view soda scs component',
    'view soda scs project',
    'view soda scs service key',
    'view soda scs snapshot',
    'view soda scs stack',
  ];

  user_role_grant_permissions('scs_user', $permissions);
}

/**
 * Propagate Keycloak user data to fields.
 */
function _soda_scs_manager_propagate_keycloak_user_data_to_fields(UserInterface $user) {
  $keycloakService = \Drupal::service('soda_scs_manager.keycloak_service.helpers');

  $keycloakToken = $keycloakService->getKeycloakToken();
  $keycloakUser = $keycloakService->getKeycloakUser($keycloakToken, $user->getDisplayName());

  // If Keycloak data is available, propagate it to user fields.
  if (!empty($keycloakUser) && is_array($keycloakUser)) {
    if (!empty($keycloakUser['firstName'])) {
      $user->set('first_name', $keycloakUser['firstName']);
    }
    if (!empty($keycloakUser['lastName'])) {
      $user->set('last_name', $keycloakUser['lastName']);
    }
    if (!empty($keycloakUser['id'])) {
      $user->set('sso_user_id', $keycloakUser['id']);
    }
    // Save the user entity after updating fields.
    $user->save();
  }
}

/**
 * Removes a deleted component from all projects' connectedComponents.
 *
 * @param \Drupal\soda_scs_manager\Entity\SodaScsComponent $component
 *   The component entity being deleted.
 */
function _soda_scs_manager_remove_component_from_projects(SodaScsComponent $component) {
  $componentId = (int) $component->id();

  $projectStorage = \Drupal::entityTypeManager()->getStorage('soda_scs_project');
  $projectIds = $projectStorage->getQuery()
    ->condition('connectedComponents', $componentId)
    ->accessCheck(FALSE)
    ->execute();

  if (empty($projectIds)) {
    return;
  }

  /** @var \Drupal\soda_scs_manager\Entity\SodaScsProject[] $projects */
  $projects = $projectStorage->loadMultiple($projectIds);

  foreach ($projects as $project) {
    $componentRefs = $project->get('connectedComponents')->getValue();
    $filtered = array_filter($componentRefs, function ($ref) use ($componentId) {
      return (int) ($ref['target_id'] ?? 0) !== $componentId;
    });
    $project->set('connectedComponents', array_values($filtered));
    $project->save();
  }
}

/**
 * Syncs the relationship from component to projects.
 *
 * @param \Drupal\soda_scs_manager\Entity\SodaScsComponent $component
 *   The component entity.
 */
function _soda_scs_manager_sync_component_project_relationship(SodaScsComponent $component) {
  // Skip if we're in the middle of syncing to prevent infinite recursion.
  if (!empty($component->syncing)) {
    return;
  }

  // Get projects referenced by this component.
  $projectIds = [];
  $partOfProjects = $component->get('partOfProjects')->getValue();
  foreach ($partOfProjects as $projectRef) {
    $projectIds[] = $projectRef['target_id'];
  }

  if (empty($projectIds)) {
    return;
  }

  // Load all referenced projects.
  $projectStorage = \Drupal::entityTypeManager()->getStorage('soda_scs_project');
  /** @var \Drupal\soda_scs_manager\Entity\SodaScsProject[] $projects */
  $projects = $projectStorage->loadMultiple($projectIds);

  // For each project, ensure it references this component.
  foreach ($projects as $project) {
    /** @var \Drupal\soda_scs_manager\Entity\SodaScsProject $project */
    $componentRefs = $project->get('connectedComponents')->getValue();
    $componentRefIds = [];
    foreach ($componentRefs as $ref) {
      $componentRefIds[] = $ref['target_id'];
    }

    // If this component is not referenced by the project, add it.
    if (!in_array($component->id(), $componentRefIds)) {
      $componentRefs[] = ['target_id' => $component->id()];
      $project->set('connectedComponents', $componentRefs);
      // Prevent infinite recursion by setting a flag.
      $project->syncing = TRUE;
      $project->save();
      // Sync MariaDB access when an SQL component is added to a project.
      if ($component->bundle() === 'soda_scs_sql_component') {
        \Drupal::service('soda_scs_manager.project_db_access.helpers')->syncProjectMembersDbAccess($project);
      }
    }
  }
}

/**
 * Syncs the relationship from project to components.
 *
 * @param \Drupal\soda_scs_manager\Entity\SodaScsProject $project
 *   The project entity.
 */
function _soda_scs_manager_sync_project_component_relationship(SodaScsProject $project) {
  // Get components referenced by this project.
  $componentIds = [];
  $connectedComponents = $project->get('connectedComponents')->getValue();
  foreach ($connectedComponents as $componentRef) {
    $componentIds[] = $componentRef['target_id'];
  }

  // Load all components that might reference this project.
  $componentStorage = \Drupal::entityTypeManager()->getStorage('soda_scs_component');

  // First, find all components that reference this project.
  $query = $componentStorage->getQuery()
    ->condition('partOfProjects', $project->id())
    ->accessCheck(FALSE);
  $referencingComponentIds = $query->execute();

  if (!empty($referencingComponentIds)) {
    $referencingComponents = $componentStorage->loadMultiple($referencingComponentIds);

    // For each component that references this project,
    // check if it should still reference it.
    /** @var \Drupal\soda_scs_manager\Entity\SodaScsComponent $component */
    foreach ($referencingComponents as $component) {
      // Skip if the component is still connected to the project.
      if (in_array($component->id(), $componentIds)) {
        continue;
      }

      // Component is no longer connected to the project, remove the reference.
      $projectRefs = [];
      foreach ($component->get('partOfProjects')->getValue() as $ref) {
        if ($ref['target_id'] != $project->id()) {
          $projectRefs[] = $ref;
        }
      }

      // Update the component with the new references.
      $component->set('partOfProjects', $projectRefs);
      // Prevent infinite recursion by setting a flag.
      $component->syncing = TRUE;
      $component->save();
    }
  }

  // If there are no components connected to this project, we're done.
  if (empty($componentIds)) {
    return;
  }

  // Load all currently referenced components.
  /** @var \Drupal\soda_scs_manager\Entity\SodaScsComponent[] $components */
  $components = $componentStorage->loadMultiple($componentIds);

  // For each component, ensure it references this project.
  foreach ($components as $component) {
    $projectRefs = $component->get('partOfProjects')->getValue();
    $projectRefIds = [];
    foreach ($projectRefs as $ref) {
      $projectRefIds[] = $ref['target_id'];
    }

    // If this project is not referenced by the component, add it.
    if (!in_array($project->id(), $projectRefIds)) {
      $projectRefs[] = ['target_id' => $project->id()];
      $component->set('partOfProjects', $projectRefs);
      // Prevent infinite recursion by setting a flag.
      $component->syncing = TRUE;
      $component->save();
    }
  }
}

/**
 * Implements hook_cron().
 *
 * Deletes operations and their steps older than one week.
 */
function soda_scs_manager_cron() {
  /** @var \Drupal\soda_scs_manager\Helpers\SodaScsProgressHelper $progressHelper */
  $progressHelper = \Drupal::service('soda_scs_manager.progress.helpers');

  // Delete operations older than 7 days (604800 seconds).
  $result = $progressHelper->deleteOldOperations(604800);

  if ($result['deleted_operations'] > 0 || $result['deleted_steps'] > 0) {
    \Drupal::logger('soda_scs_manager')->info('Cron job: Deleted @operations operations and @steps steps older than 7 days.', [
      '@operations' => $result['deleted_operations'],
      '@steps' => $result['deleted_steps'],
    ]);
  }
}

/**
 * Implements hook_menu_links_discovered_alter().
 */
function soda_scs_manager_menu_links_discovered_alter(array &$links): void {
  $documentation_book_uuid = '10e1bd5d-8405-4485-811e-24e0695b76b6';
  $documentation_link_ids = [
    'soda_scs_manager.menu.documentation',
    'soda_scs_manager.anonymous_documentation',
  ];
  $storage = \Drupal::entityTypeManager()->getStorage('node');
  $nodes = $storage->loadByProperties(['uuid' => $documentation_book_uuid]);
  $node = reset($nodes);

  foreach ($documentation_link_ids as $id) {
    if (!isset($links[$id])) {
      continue;
    }
    if ($node instanceof NodeInterface) {
      $links[$id]['route_name'] = 'entity.node.canonical';
      $links[$id]['route_parameters'] = ['node' => (string) $node->id()];
      $links[$id]['cache_tags'] = array_merge($links[$id]['cache_tags'] ?? [], ['node:' . $node->id()]);
    }
    else {
      $links[$id]['route_name'] = '<front>';
      unset($links[$id]['route_parameters']);
    }
  }
}

/**
 * Implements hook_preprocess_menu().
 */
function soda_scs_manager_preprocess_menu(&$variables): void {
  $menu_name = (string) ($variables['menu_name'] ?? '');

  if ($menu_name === 'account') {
    if (!isset($variables['#cache'])) {
      $variables['#cache'] = [];
    }
    if (!isset($variables['#cache']['contexts'])) {
      $variables['#cache']['contexts'] = [];
    }
    $variables['#cache']['contexts'][] = 'user';
    $variables['#cache']['contexts'][] = 'url.path';
    _soda_scs_manager_preprocess_menu_account_user_display_name_recursive($variables['items']);
    _soda_scs_manager_menu_mark_current_link_recursive($variables['items']);
    return;
  }

  if ($menu_name !== 'main') {
    return;
  }

  // Ensure the main menu is cached per user so the notification badge
  // reflects the current account's pending invitations.
  if (!isset($variables['#cache'])) {
    $variables['#cache'] = [];
  }
  if (!isset($variables['#cache']['contexts'])) {
    $variables['#cache']['contexts'] = [];
  }
  $variables['#cache']['contexts'][] = 'user';

  // Two YAML links target the same documentation node route; both would pass
  // access for anonymous users. Show one Documentation item per session state.
  if (\Drupal::currentUser()->isAuthenticated()) {
    unset($variables['items']['soda_scs_manager.anonymous_documentation']);
  }
  else {
    unset($variables['items']['soda_scs_manager.menu.documentation']);
  }

  // Retired parent link: flatten cached trees until rebuild picks up YAML.
  if (isset($variables['items']['soda_scs_manager.main_navigation'])) {
    $legacy_parent = $variables['items']['soda_scs_manager.main_navigation'];
    unset($variables['items']['soda_scs_manager.main_navigation']);
    if (!empty($legacy_parent['below']) && is_array($legacy_parent['below'])) {
      foreach ($legacy_parent['below'] as $id => $child) {
        if (!isset($variables['items'][$id])) {
          $variables['items'][$id] = $child;
        }
      }
    }
  }

  // Issue Report is for the Footer menu only; strip from main if mis-placed.
  _soda_scs_manager_menu_remove_link_from_tree($variables['items'], 'soda_scs_manager.menu.issue_report');

  _soda_scs_manager_preprocess_menu_notifications_recursive($variables['items']);

  // Exact current item: class + underline styling do not rely on active-link.js alone.
  // The main menu block uses a BigPipe placeholder; markup can appear before JS runs.
  _soda_scs_manager_menu_mark_current_link_recursive($variables['items']);
  $variables['#cache']['contexts'][] = 'url.path';
  $variables['#cache']['contexts'][] = 'url.path.is_front';
}

/**
 * Replaces the "My account" label (user.page) with the current user's name.
 *
 * @param array $items
 *   Account menu items from template_preprocess_menu() (by reference).
 */
function _soda_scs_manager_preprocess_menu_account_user_display_name_recursive(array &$items): void {
  $current = \Drupal::currentUser();
  if (!$current->isAuthenticated()) {
    return;
  }
  $user = \Drupal::entityTypeManager()->getStorage('user')->load($current->id());
  $label = $user instanceof UserInterface ? $user->getDisplayName() : $current->getDisplayName();
  if ($label === '') {
    $label = $current->getAccountName();
  }
  if ($label === '') {
    return;
  }
  foreach ($items as &$item) {
    if (!empty($item['url']) && $item['url'] instanceof Url
      && $item['url']->isRouted()
      && $item['url']->getRouteName() === 'user.page') {
      $item['title'] = $label;
    }
    if (!empty($item['below']) && is_array($item['below'])) {
      _soda_scs_manager_preprocess_menu_account_user_display_name_recursive($item['below']);
    }
  }
  unset($item);
}

/**
 * Adds is-active and aria-current="page" for the link matching the request.
 *
 * Like core active-link matching (path + query) for the top nav when BigPipe or
 * delayed JS would otherwise hide the current item.
 *
 * When path comparison fails, compares route + parameters on the menu Url
 * (PathValidator resolves internal: aliases to entity routes) or on the plugin.
 *
 * @param array $items
 *   Menu tree from template_preprocess_menu(), by reference.
 */
function _soda_scs_manager_menu_mark_current_link_recursive(array &$items): void {
  $route_match = \Drupal::routeMatch();
  if ($route_match instanceof StackedRouteMatchInterface) {
    $route_match = $route_match->getMasterRouteMatch();
  }
  if (!$route_match->getRouteName()) {
    return;
  }
  $current_url = Url::fromRouteMatch($route_match);
  $current_path = '';
  if ($current_url->isRouted()) {
    $current_path = $current_url->getInternalPath();
  }
  $request_query = \Drupal::request()->query->all();
  ksort($request_query);

  foreach ($items as &$item) {
    if (!empty($item['url']) && $item['url'] instanceof Url) {
      $url = $item['url'];
      $is_current = FALSE;

      if ($current_path !== '' && $url->isRouted() && !$url->isExternal()
        && $url->getRouteName() !== '<nolink>') {
        $link_query = $url->getOption('query') ?? [];
        $is_current = (
          _soda_scs_manager_menu_link_query_matches_request($link_query, $request_query)
          && $url->getInternalPath() === $current_path
        );
      }

      if (!$is_current && $url->isRouted() && !$url->isExternal()
        && $url->getRouteName() !== '<nolink>') {
        $is_current = _soda_scs_manager_menu_link_route_definition_matches_current(
          $url->getRouteName(),
          $url->getRouteParameters(),
          $route_match,
          $request_query,
          $url,
        );
      }

      if (!$is_current
        && !empty($item['original_link'])
        && $item['original_link'] instanceof MenuLinkInterface) {
        $is_current = _soda_scs_manager_menu_link_route_matches_current(
          $item['original_link'],
          $route_match,
          $request_query,
          $url,
        );
      }

      // "My account" uses route user.page (/user) but the profile is
      // entity.user.canonical (/user/2); path and route names differ.
      if (!$is_current && $url->isRouted() && !$url->isExternal()
        && $url->getRouteName() === 'user.page') {
        $is_current = _soda_scs_manager_menu_user_page_matches_canonical_profile(
          $route_match,
          $request_query,
          $url,
        );
      }

      // Home uses route <front> (internal path "" / URL /) while the configured
      // front page is served by another route (e.g. dashboard, node/N).
      if (!$is_current && $url->isRouted() && !$url->isExternal()
        && $url->getRouteName() === '<front>') {
        $is_current = _soda_scs_manager_menu_front_link_matches_current_page(
          $request_query,
          $url,
        );
      }

      if ($is_current) {
        $url->mergeOptions([
          'attributes' => [
            'class' => ['is-active'],
            'aria-current' => 'page',
          ],
        ]);
      }
    }
    if (!empty($item['below']) && is_array($item['below'])) {
      _soda_scs_manager_menu_mark_current_link_recursive($item['below']);
    }
  }
  unset($item);
}

/**
 * TRUE if the request query string satisfies the menu link query option.
 *
 * When the link defines no query (empty), any request query is accepted so
 * incidental parameters (e.g. ?destination=) do not block the active state.
 */
function _soda_scs_manager_menu_link_query_matches_request(
  array $link_query,
  array $request_query,
): bool {
  if ($link_query === []) {
    return TRUE;
  }
  ksort($link_query);
  ksort($request_query);
  return $link_query === $request_query;
}

/**
 * TRUE if "My account" (user.page) should match the current profile page.
 *
 * Core uses user.page for /user; the profile view is entity.user.canonical
 * (/user/{user}). Mark active only when that user is the logged-in account.
 */
function _soda_scs_manager_menu_user_page_matches_canonical_profile(
  RouteMatchInterface $route_match,
  array $request_query,
  Url $menu_url,
): bool {
  if ($route_match->getRouteName() !== 'entity.user.canonical') {
    return FALSE;
  }
  $account = \Drupal::currentUser();
  if (!$account->isAuthenticated()) {
    return FALSE;
  }
  $user_param = $route_match->getParameter('user');
  if ($user_param instanceof UserInterface) {
    $page_uid = (string) $user_param->id();
  }
  elseif ($user_param !== NULL && $user_param !== '') {
    $page_uid = (string) $user_param;
  }
  else {
    return FALSE;
  }
  if ($page_uid !== (string) $account->id()) {
    return FALSE;
  }
  $link_query = $menu_url->getOption('query') ?? [];

  return _soda_scs_manager_menu_link_query_matches_request($link_query, $request_query);
}

/**
 * TRUE if a menu link to the special front route should match this request.
 *
 * Core MenuActiveTrail treats <front> links as active on the configured home
 * page even though that page uses another route (node, custom route, etc.).
 */
function _soda_scs_manager_menu_front_link_matches_current_page(
  array $request_query,
  Url $menu_url,
): bool {
  if (!\Drupal::service('path.matcher')->isFrontPage()) {
    return FALSE;
  }
  $link_query = $menu_url->getOption('query') ?? [];

  return _soda_scs_manager_menu_link_query_matches_request($link_query, $request_query);
}

/**
 * TRUE if route name/parameters match the request (and query on $menu_url).
 */
function _soda_scs_manager_menu_link_route_definition_matches_current(
  string $link_route,
  array $link_route_params,
  RouteMatchInterface $route_match,
  array $request_query,
  Url $menu_url,
): bool {
  if ($link_route === ''
    || $link_route === '<nolink>'
    || $link_route === '<button>') {
    return FALSE;
  }
  if ($link_route !== $route_match->getRouteName()) {
    return FALSE;
  }
  foreach ($link_route_params as $key => $expected) {
    $current = $route_match->getParameter($key);
    if ($current === NULL) {
      return FALSE;
    }
    if ($current instanceof EntityInterface) {
      $current = (string) $current->id();
    }
    else {
      $current = (string) $current;
    }
    if ($current !== (string) $expected) {
      return FALSE;
    }
  }

  $link_query = $menu_url->getOption('query') ?? [];

  return _soda_scs_manager_menu_link_query_matches_request($link_query, $request_query);
}

/**
 * TRUE if the menu link plugin matches route, parameters, and query.
 *
 * Used when the menu Url is unrouted so PathValidator route data is absent.
 */
function _soda_scs_manager_menu_link_route_matches_current(
  MenuLinkInterface $link,
  RouteMatchInterface $route_match,
  array $request_query,
  Url $menu_url,
): bool {
  return _soda_scs_manager_menu_link_route_definition_matches_current(
    $link->getRouteName(),
    $link->getRouteParameters(),
    $route_match,
    $request_query,
    $menu_url,
  );
}

/**
 * Removes a menu link (by plugin id) from a preprocessed menu tree at any depth.
 *
 * @param array $items
 *   Menu items from template_preprocess_menu(), by reference.
 * @param string $plugin_id
 *   The menu link plugin ID to strip.
 */
function _soda_scs_manager_menu_remove_link_from_tree(array &$items, string $plugin_id): void {
  unset($items[$plugin_id]);
  foreach ($items as &$item) {
    if (!empty($item['below']) && is_array($item['below'])) {
      _soda_scs_manager_menu_remove_link_from_tree($item['below'], $plugin_id);
    }
  }
}

/**
 * TRUE if this menu tree entry is the SCS Manager notifications page link.
 *
 * Matches the default YAML plugin id, the notifications route, internal path, and aliases.
 *
 * @param array $item
 *   A single menu item from template_preprocess_menu().
 * @param string $tree_key
 *   The key for this item in the menu tree (menu link plugin id).
 */
function _soda_scs_manager_menu_item_is_notifications_link(array $item, string $tree_key): bool {
  if ($tree_key === 'soda_scs_manager.menu.notifications') {
    return TRUE;
  }
  if (!isset($item['url']) || !($item['url'] instanceof Url)) {
    return FALSE;
  }
  $url = $item['url'];
  if ($url->getRouteName() === 'soda_scs_manager.notifications') {
    return TRUE;
  }
  if ($url->isExternal()) {
    return FALSE;
  }
  try {
    $internalPath = $url->getInternalPath();
  }
  catch (\Throwable) {
    return FALSE;
  }
  $normalized = trim($internalPath, '/');
  if ($normalized === 'soda-scs-manager/notifications') {
    return TRUE;
  }
  if (\Drupal::hasService('path_alias.manager')) {
    $systemPath = trim((string) \Drupal::service('path_alias.manager')->getPathByAlias('/' . ltrim($internalPath, '/')), '/');
    return $systemPath === 'soda-scs-manager/notifications';
  }
  return FALSE;
}

/**
 * Adds visible notification label markup to the notifications link (including when nested).
 *
 * @param array $items
 *   Menu items from template_preprocess_menu() (by reference).
 */
function _soda_scs_manager_preprocess_menu_notifications_recursive(array &$items): void {
  foreach ($items as $tree_key => &$item) {
    if (_soda_scs_manager_menu_item_is_notifications_link($item, (string) $tree_key)) {
      $currentUser = \Drupal::currentUser();
      $count = 0;

      if ($currentUser->isAuthenticated()) {
        $storage = \Drupal::entityTypeManager()->getStorage('soda_scs_project_membership');
        $query = $storage->getQuery()
          ->condition('recipient', $currentUser->id())
          ->condition('status', 'pending')
          ->accessCheck(FALSE);
        $count = $query->count()->execute();
      }

      if ($count > 0) {
        $item['title'] = new TranslatableMarkup('<span class="notification-icon-wrapper"><span class="notification-icon">@label</span><span class="notification-dot"></span></span><span class="visually-hidden">@title (@count)</span>', [
          '@label' => t('Notifications'),
          '@title' => $item['title'],
          '@count' => $count,
        ]);
        $item['attributes']->addClass('menu-item--notifications');
        $item['attributes']->addClass('scs-manager--notifications-menu-item');
        $item['attributes']->addClass('has-notifications');
      }
      else {
        $item['title'] = new TranslatableMarkup('<span class="notification-icon-wrapper"><span class="notification-icon">@label</span></span><span class="visually-hidden">@title</span>', [
          '@label' => t('Notifications'),
          '@title' => $item['title'],
        ]);
        $item['attributes']->addClass('menu-item--notifications');
        $item['attributes']->addClass('scs-manager--notifications-menu-item');
      }
    }
    if (!empty($item['below'])) {
      _soda_scs_manager_preprocess_menu_notifications_recursive($item['below']);
    }
  }
}
