{{ entity_type|replace({'soda_scs_': ''}) }}
<div class="soda-scs-manager--type--card">
  <div class="soda-scs-manager--card-type">
    {{ bundle_label }}
  </div>
    {% set tags_hidden_from_ui = ['data-science', 'publishing'] %}
    <div class="soda-scs-manager--card-tags mb-4">
      {% for tag in tags|sort %}
        {% if tag not in tags_hidden_from_ui %}
        <span class="soda-scs-manager--tag-filter-button soda-scs-manager--card-tag rounded-full px-2 py-1 text-xs whitespace-nowrap
        {% if tag == 'coding' %}
          bg-purple-100 text-purple-700 hover:bg-purple-200
        {% elseif tag == 'cms' %}
          bg-blue-100 text-blue-700 hover:bg-blue-200
        {% elseif tag == 'database' %}
          bg-emerald-100 text-emerald-700 hover:bg-emerald-200
        {% elseif tag == 'data-cleaning' %}
          bg-green-100 text-green-700 hover:bg-green-200
        {% elseif tag == 'filesharing' %}
          bg-cyan-100 text-cyan-700 hover:bg-cyan-200
        {% elseif tag == 'ontology' %}
          bg-indigo-100 text-indigo-700 hover:bg-indigo-200
        {% elseif tag == 'office' %}
          bg-orange-100 text-orange-700 hover:bg-orange-200
        {% elseif tag == 'triplestore' %}
          bg-lime-100 text-lime-700 hover:bg-lime-200
        {% else %}
          bg-stone-100 text-stone-700 hover:bg-stone-200
        {% endif %}" data-tag="{{ tag }}" role="button" tabindex="0" aria-pressed="false" aria-label="{{ 'Filter by tag @tag'|t({'@tag': tag}) }}">{{ tag|t }}</span>
        {% endif %}
      {% endfor %}
    </div>
    {% set isRunning = health_status == 'running' or health_status == 'healthy' %}
    {% set health_lower = health_status|default('')|lower %}
    {% set overlayTone = '' %}
    {% if not isRunning %}
      {% if health_lower == 'starting' %}
        {% set overlayTone = ' soda-scs-manager--card--status-starting' %}
      {% elseif health_status == 'stopped' or health_status == 'paused' %}
        {% set overlayTone = ' soda-scs-manager--card--status-stopped' %}
      {% elseif health_status == 'Unknown' or health_status == 'unknown' %}
        {% set overlayTone = '' %}
      {% elseif health_status == 'unhealthy' or health_status == 'unavailable' %}
        {% set overlayTone = ' soda-scs-manager--card--status-offline' %}
      {% else %}
        {% set overlayTone = ' soda-scs-manager--card--status-offline' %}
      {% endif %}
    {% endif %}
    <div class="soda-scs-manager--card-content-wrapper{% if not isRunning %} soda-scs-manager--card--not-running{{ overlayTone }}{% endif %}"
      {% if entity_id %}data-entity-id="{{ entity_id }}"{% endif %}
      {% if entity_type_id %}data-entity-type="{{ entity_type_id }}"{% endif %}>
      <div class="soda-scs-manager--card-status-banner" aria-live="polite">
        {% if not isRunning %}
          {% if health_lower == 'starting' %}
            <div class="soda-scs-manager--card-status-banner__throbber" role="presentation" aria-hidden="true"></div>
            <p class="soda-scs-manager--card-status-banner__primary">{{ 'Startup in progress'|t }}</p>
            <p class="soda-scs-manager--card-status-banner__secondary">{{ 'Containers and services are being provisioned. This may take several minutes; status updates automatically.'|t }}</p>
          {% elseif health_status == 'Unknown' or health_status == 'unknown' %}
            <p class="soda-scs-manager--card-status-banner__primary">{{ 'Checking status'|t }}</p>
            <p class="soda-scs-manager--card-status-banner__secondary">{{ 'We have not confirmed whether this application is running yet. The dashboard checks automatically in the background.'|t }}</p>
          {% elseif health_status == 'stopped' or health_status == 'paused' %}
            <p class="soda-scs-manager--card-status-banner__primary">{{ 'Stopped'|t }}</p>
            <p class="soda-scs-manager--card-status-banner__secondary">{{ 'This application is not running.'|t }}</p>
          {% elseif health_status == 'unhealthy' or health_status == 'unavailable' %}
            <p class="soda-scs-manager--card-status-banner__primary">{{ 'Application offline'|t }}</p>
            <p class="soda-scs-manager--card-status-banner__secondary">{{ 'If you need help, contact your site administrator.'|t }}</p>
          {% else %}
            <p class="soda-scs-manager--card-status-banner__primary">{{ 'Application offline'|t }}</p>
            <p class="soda-scs-manager--card-status-banner__secondary">{{ 'If you need help, contact your site administrator.'|t }}</p>
          {% endif %}
        {% endif %}
      </div>
      {% if health_status %}
        {% set healthClass = 'unknown' %}
        {% set healthTitle = 'Unknown'|t %}
        {% if health_status == 'running' or health_status == 'healthy' %}
          {% set healthClass = 'running' %}
          {% set healthTitle = 'Running'|t %}
        {% elseif health_status == 'unavailable' %}
          {% set healthClass = 'failure' %}
          {% set healthTitle = 'Unavailable'|t %}
        {% elseif health_lower == 'starting' %}
          {% set healthClass = 'starting' %}
          {% set healthTitle = 'Starting'|t %}
        {% elseif health_status == 'Unknown' or health_status == 'unknown' %}
          {% set healthClass = 'unknown' %}
          {% set healthTitle = 'Unknown'|t %}
        {% elseif health_status == 'paused' %}
          {% set healthClass = 'stopped' %}
          {% set healthTitle = 'Paused'|t %}
        {% elseif health_status == 'stopped' %}
          {% set healthClass = 'stopped' %}
          {% set healthTitle = 'Stopped'|t %}
        {% elseif health_status == 'unhealthy' %}
          {% set healthClass = 'failure' %}
          {% set healthTitle = 'Failure'|t %}
        {% endif %}
      <span class="soda-scs-manager--health-icon soda-scs-manager--health-{{ healthClass }}"
            aria-label="{{ 'Health status: @status'|t({'@status': healthTitle}) }}"
            title="{{ healthTitle }}">
      </span>
      {% endif %}
      {% if details_link %}
      <a href="{{ details_link }}"
         class="soda-scs-manager--card-icon soda-scs-manager--details-icon"
         aria-label="{{ 'View details of @title'|t({'@title': title}) }}"
         title="{{ 'View details'|t }}"></a>
      {% endif %}
      <a href="{{ learn_more_link }}"
         class="soda-scs-manager--card-icon soda-scs-manager--book-icon"
         aria-label="{{ 'View documentation for @title'|t({'@title': title}) }}"
         title="{{ 'Documentation'|t }}"></a>
      {% if url %}
      <a href="{{ url }}" class="soda-scs-manager--card-link" target="_blank"></a>
      {% endif %}
      <div class="soda-scs-manager--image-wrapper">
        <img class="soda-scs-manager--card-img-top " src="{{ file_url(imageUrl) }}" alt="{{ label }}">
      </div>
      <div class="soda-scs-manager--card-body ">
        <h5 class="soda-scs-manager--card-title">{{ title }}</h5>
        <p class="soda-scs-manager--card-text">{{ description }}</p>
      </div>
    </div>
</div>
