{#
/**
 * @file
 * Default theme implementation for a SODa SCS Project entity view.
 *
 * Available variables:
 * - label: Project label.
 * - owner: Rendered owner field.
 * - members: Rendered members field.
 * - note: Rendered note field.
 * - application_cards: Dashboard-style cards for connected applications.
 * - attributes: HTML attributes for the container.
 * - filter_tags: Tag machine names for the application filter bar.
 *
 * @ingroup themeable
 */
#}

<article{{ attributes }}>
  <header class="scs-manager--project-view--header mb-8">
    <h1 class="soda-scs-manager--dashboard-heading-section text-center">{{ label }}</h1>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
    {% if owner %}
      <div class="rounded-lg border border-stone-200 bg-white p-4 shadow-sm">
        {{ owner }}
      </div>
    {% endif %}
    <div class="rounded-lg border border-stone-200 bg-white p-4 shadow-sm">
      {{ members }}
    </div>
  </div>

  {% if note %}
    <div class="rounded-lg border border-stone-200 bg-white p-4 shadow-sm mb-10">
      {{ note }}
    </div>
  {% endif %}

  <div class="text-center mb-8">
    <h2 class="soda-scs-manager--dashboard-heading-section">{{ 'Applications'|t }}</h2>
  </div>

  {% if application_cards is not empty %}
    {% include '@soda_scs_manager/includes/soda-scs-manager--tag-filter.html.twig' with {
      filter_tags: filter_tags,
    } only %}
  {% endif %}

  {% if application_cards is not empty %}
    {% set application_count = application_cards|length %}
    {% set grid_class = 'grid-count-' ~ application_count %}
    <div class="soda-scs-manager--view--grid mb-12 {{ grid_class }}">
      {% for card in application_cards %}
        {{ card }}
      {% endfor %}
    </div>
  {% else %}
    <div class="alert alert-info opacity-90 bg-slate-950 border-2 border-stone-200 shadow-lg shadow-cyan-500/50 p-4 rounded-lg text-center">
      <p class="text-stone-200 text-xl">{{ 'No applications found.'|t }}</p>
    </div>
  {% endif %}
</article>
