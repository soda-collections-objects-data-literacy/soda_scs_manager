{#
/**
 * @file
 * Co-working introduction wizard markup (dashboard and start page).
 *
 * Slide order is driven by data-coworking-intro-slide in this file (0..5). coworkingIntroWizard.js
 * uses the same indices for Next / Back gating, Nextcloud connection, and WissKI flow.
 * Steps 1–5: static line/dot under the panel title (panel divider); step 0 uses the animated divider inside the welcome slide.
 * Main copy blocks use data-coworking-intro-copy-rise; coworkingIntroWizard.js sets data-coworking-intro-copy-replay per step.
 * Layout and Tailwind utilities live in soda_scs_manager_theme intro-wizard.pcss (scs-manager--coworking-intro-*).
 *
 * Variables:
 * - intro_asset_base: Base URL for module SVGs.
 * - intro_connected_accounts_url: Connected Accounts URL.
 * - intro_gif_src: GIF URL when MP4 is absent (assets/images or assets/videos intro.gif).
 * - intro_mp4_src: MP4 URL for slide 0 Welcome (assets/videos/slide_1.mp4); shown instead of GIF.
 * - intro_mp4_src_2: MP4 URL for slide 1 Manager of Services and Projects (assets/videos/slide_2.mp4).
 * - intro_mp4_src_3: MP4 URL for slide 2 Your Dashboard (assets/videos/slide_3.mp4).
 *
 * @ingroup themeable
 */
#}
<div id="scs-manager--coworking-intro" class="scs-manager--coworking-intro" role="dialog" aria-modal="true" aria-labelledby="scs-manager--coworking-intro-title" data-coworking-intro-root data-coworking-intro-active-slide="0">
  <div class="scs-manager--coworking-intro-panel">
    <div class="scs-manager--coworking-intro-header">
      <div class="scs-manager--coworking-intro-skip-row">
        <button type="button" class="scs-manager--coworking-intro-skip" data-coworking-intro-skip>{{ 'Skip introduction'|t }}</button>
      </div>
      <h2 id="scs-manager--coworking-intro-title" class="scs-manager--coworking-intro-title">{{ 'Welcome to the Semantic Co-Working Space!'|t }}</h2>
    </div>

    <div class="scs-manager--coworking-intro-panel-divider">
      {% include '@soda_scs_manager/includes/soda-scs-manager--coworking-intro-divider-static.html.twig' %}
    </div>

    <div class="scs-manager--coworking-intro-scroll-body">
      {# Slides 0–2: onboarding copy. #}
      <div class="scs-manager--coworking-intro-slide" data-coworking-intro-slide="0">
        {# Same visual language as the page menu-bar divider; animates in-panel (see intro-wizard.pcss + coworkingIntroWizard.js). #}
        <div class="scs-manager--coworking-intro-welcome-divider" data-coworking-intro-welcome-divider role="presentation" aria-hidden="true">
          <div class="scs-manager--coworking-intro-welcome-divider-track">
            <div class="scs-manager--coworking-intro-welcome-divider-line"></div>
            <div class="scs-manager--coworking-intro-welcome-divider-dot"></div>
          </div>
        </div>
        {% if intro_mp4_src %}
          <div class="scs-manager--coworking-intro-welcome-visual-wrap" data-coworking-intro-copy-rise>
            <video class="scs-manager--coworking-intro-welcome-visual" autoplay loop muted playsinline preload="metadata" aria-label="{{ 'Introduction to the Semantic Co-Working Space'|t }}" width="1080" height="600">
              <source src="{{ intro_mp4_src }}" type="video/mp4">
              {{ 'Your browser does not support the video tag.'|t }}
            </video>
          </div>
        {% elseif intro_gif_src %}
          <div class="scs-manager--coworking-intro-welcome-visual-wrap" data-coworking-intro-copy-rise>
            <img class="scs-manager--coworking-intro-welcome-visual" src="{{ intro_gif_src }}" alt="{{ 'Introduction to the Semantic Co-Working Space'|t }}" width="1080" height="600" loading="lazy" decoding="async">
          </div>
        {% endif %}
        <div class="scs-manager--coworking-intro-welcome-content scs-manager--coworking-intro-copy-rise" data-coworking-intro-copy-rise>
          <h3 class="scs-manager--coworking-intro-subtitle">{{ 'Hi there!'|t }}</h3>
          <p>{{ 'Here you find all tools to support your work through the collection data life cycle – from capture and cleaning to publishing of FAIR and linked data.'|t }}</p>
          <p>{{ 'The next steps highlight some features and guide you through the initial configuration and help you set up a WissKI environment.'|t }}</p>
        </div>
      </div>

      <div class="scs-manager--coworking-intro-slide scs-manager--coworking-intro-slide--hidden" data-coworking-intro-slide="1">
        {% if intro_mp4_src_2 %}
          <div class="scs-manager--coworking-intro-welcome-visual-wrap" data-coworking-intro-copy-rise>
            <video class="scs-manager--coworking-intro-welcome-visual" autoplay loop muted playsinline preload="metadata" aria-label="{{ 'Manager of Services and Projects'|t }}" width="1080" height="600">
              <source src="{{ intro_mp4_src_2 }}" type="video/mp4">
              {{ 'Your browser does not support the video tag.'|t }}
            </video>
          </div>
        {% endif %}
        <div class="scs-manager--coworking-intro-copy-rise" data-coworking-intro-copy-rise>
          <h3 class="scs-manager--coworking-intro-subtitle">{{ 'Manager of Services and Projects.'|t }}</h3>
          <p>{{ 'The Semantic Co-Working Space (SCS) provides selected applications for digital collection management. The SCS is the main access point to these applications and you can manage them in a user-friendly webinterface. The SCS is built to work together, so our main services support collaborative work and data integration between applications. You can easily share the access to your applications with other SCS users.'|t }}</p>
        </div>
      </div>

      <div class="scs-manager--coworking-intro-slide scs-manager--coworking-intro-slide--hidden" data-coworking-intro-slide="2">
        {% if intro_mp4_src_3 %}
          <div class="scs-manager--coworking-intro-welcome-visual-wrap" data-coworking-intro-copy-rise>
            <video class="scs-manager--coworking-intro-welcome-visual" autoplay loop muted playsinline preload="metadata" aria-label="{{ 'Your Dashboard'|t }}" width="1080" height="600">
              <source src="{{ intro_mp4_src_3 }}" type="video/mp4">
              {{ 'Your browser does not support the video tag.'|t }}
            </video>
          </div>
        {% endif %}
        <div class="scs-manager--coworking-intro-copy-rise" data-coworking-intro-copy-rise>
          <h3 class="scs-manager--coworking-intro-subtitle">{{ 'Your Dashboard'|t }}</h3>
          <p>{{ 'The Dashboard helps to manage your applications. Clicking on the application name will open the application in a new tab. Here you can create your own WissKI environment to manage your collection data, deploy a relational database or triplestore. The cards show the health status, and you can access the corresponding documentation pages and gain some more information on the application page.'|t }}</p>
        </div>
      </div>

      {# Slide 3: manual Drive connect — only reached when automatic SSO check failed (coworkingIntroWizard.js). #}
      <div class="scs-manager--coworking-intro-slide scs-manager--coworking-intro-slide--hidden" data-coworking-intro-slide="3" data-coworking-intro-nextcloud-slide>
        <div class="scs-manager--coworking-intro-copy-rise" data-coworking-intro-copy-rise>
          <h3 class="scs-manager--coworking-intro-subtitle">{{ 'Connect Nextcloud'|t }}</h3>
          <p class="scs-manager--coworking-intro-slide-lede">{{ 'Automatic SSO connection to Drive did not work. Connect manually once via the button below — a popup opens where you sign in with Keycloak. Allow popups for this site when prompted.'|t }}</p>
          <div class="scs-manager--nextcloud-connect-wrapper scs-manager--nextcloud-connect-inline">
            <button type="button" class="scs-manager--nextcloud-connect-btn">{{ 'Connect Drive manually'|t }}</button>
            <p class="scs-manager--nextcloud-connect-status-inline scs-manager--coworking-intro-nextcloud-status" data-status="unknown">{{ 'Checking connection…'|t }}</p>
            <p class="scs-manager--nextcloud-connect-fallback-hint scs-manager--coworking-intro-nextcloud-hint">{{ 'If SSO fails, click Connect Drive manually and sign in with the same Keycloak account as SCS Manager.'|t }}</p>
          </div>
          <p class="scs-manager--coworking-intro-sso-note">{{ 'For OpenID / SSO account linking:'|t }} <a href="{{ intro_connected_accounts_url }}" class="scs-manager--coworking-intro-text-link">{{ 'Open Connected Accounts'|t }}</a></p>
        </div>
      </div>

      {# Slide 4: WissKI quick-create; POST + name check URLs from drupalSettings.sodaScsManager.coworkingIntro. #}
      <div class="scs-manager--coworking-intro-slide scs-manager--coworking-intro-slide--hidden" data-coworking-intro-slide="4">
        <div class="scs-manager--coworking-intro-copy-rise" data-coworking-intro-copy-rise>
          <h3 class="scs-manager--coworking-intro-subtitle">{{ 'Create your first WissKI Environment'|t }}</h3>
          <p class="scs-manager--coworking-intro-slide-lede">{{ 'We create a complete environment: database, triplestore, and WissKI. Provisioning starts immediately and may take several minutes.'|t }}</p>
          <label for="scs-manager--coworking-intro-wisski-name" class="scs-manager--coworking-intro-field-label">{{ 'WissKI name'|t }}</label>
          <p id="scs-manager--coworking-intro-wisski-name-hint" class="scs-manager--coworking-intro-field-hint">{{ 'Use at most 25 characters: letters (A–Z, a–z), digits (0–9), and spaces. No other symbols.'|t }}</p>
          <input id="scs-manager--coworking-intro-wisski-name" type="text" class="scs-manager--coworking-intro-wisski-name-input" maxlength="25" autocomplete="off" data-coworking-intro-wisski-name placeholder="{{ 'e.g. My collection workspace'|t }}" aria-describedby="scs-manager--coworking-intro-wisski-name-hint" />
          <p id="scs-manager--coworking-intro-wisski-name-error" class="scs-manager--coworking-intro-field-error" data-coworking-intro-wisski-error role="alert" aria-live="polite" hidden></p>
          <div class="scs-manager--coworking-intro-form-actions">
            <button type="button" class="scs-manager--coworking-intro-btn-create-wisski" data-coworking-intro-open-wisski>{{ 'Create WissKI Environment'|t }}</button>
            <button type="button" class="scs-manager--coworking-intro-btn-outlined" data-coworking-intro-finish>{{ 'Finish without creating'|t }}</button>
          </div>
        </div>
      </div>

      {# Slide 5: after successful WissKI create (server sets coworking_intro_completed); Close reloads the dashboard. #}
      <div class="scs-manager--coworking-intro-slide scs-manager--coworking-intro-slide--hidden" data-coworking-intro-slide="5" data-coworking-intro-success-slide>
        <div class="scs-manager--coworking-intro-copy-rise" data-coworking-intro-copy-rise>
          <h3 class="scs-manager--coworking-intro-success-title">{{ 'WissKI Environment created'|t }}</h3>
          <p class="scs-manager--coworking-intro-success-summary" data-coworking-intro-success-summary></p>
          <p class="scs-manager--coworking-intro-success-note">{{ 'Provisioning can take several minutes. You can monitor the applications Health Status from your dashboard or open the details page now.'|t }}</p>
          <a href="#" class="scs-manager--coworking-intro-text-link scs-manager--coworking-intro-success-details-link scs-manager--coworking-intro-success-details-link--pending" data-coworking-intro-success-details-link>{{ 'Open application details'|t }}</a>
        </div>
        <div class="scs-manager--coworking-intro-success-footer">
          <button type="button" class="scs-manager--coworking-intro-btn-close" data-coworking-intro-close-success>{{ 'Close introduction'|t }}</button>
        </div>
      </div>
    </div>

    <div class="scs-manager--coworking-intro-footer">
      <p class="scs-manager--coworking-intro-step-label" data-coworking-intro-step-label aria-live="polite"></p>
      <div class="scs-manager--coworking-intro-footer-actions">
        <button type="button" class="scs-manager--coworking-intro-btn-back" data-coworking-intro-back disabled>{{ 'Back'|t }}</button>
        <button type="button" class="scs-manager--coworking-intro-btn-next" data-coworking-intro-next>{{ 'Next'|t }}</button>
      </div>
    </div>
  </div>
</div>
