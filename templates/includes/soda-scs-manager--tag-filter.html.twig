{#
/**
 * @file
 * Tag filter bar for application card grids.
 *
 * Available variables:
 * - filter_tags: List of tag machine names to show as filter buttons.
 * - show_clear_button: Whether to render the "Clear all filters" control.
 *
 * @ingroup themeable
 */
#}
{% if filter_tags is not empty %}
<div class="soda-scs-manager--tag-filter-container p-2 rounded-lg align-center justify-center">
  <h3 class="soda-scs-manager--dashboard-heading-filter">{{ 'Filter by Tags'|t }}</h3>
  <div class="soda-scs-manager--tag-filter flex flex-wrap gap-2 justify-center" data-active-tags="[]">
    {% for tag in filter_tags|sort %}
      <button type="button" class="soda-scs-manager--tag-filter-button rounded-full px-3 py-1.5 text-sm flex items-center gap-1.5 cursor-pointer transition-all
        {% if tag == 'coding' %}
          bg-purple-100 text-purple-700 hover:bg-purple-200
        {% elseif tag == 'cms' %}
          bg-blue-100 text-blue-700 hover:bg-blue-200
        {% elseif tag == 'database' %}
          bg-emerald-100 text-emerald-700 hover:bg-emerald-200
        {% elseif tag == 'data-cleaning' %}
          bg-green-100 text-green-700 hover:bg-green-200
        {% elseif tag == 'filesharing' %}
          bg-cyan-100 text-cyan-700 hover:bg-cyan-200
        {% elseif tag == 'ontology' %}
          bg-indigo-100 text-indigo-700 hover:bg-indigo-200
        {% elseif tag == 'office' %}
          bg-orange-100 text-orange-700 hover:bg-orange-200
        {% elseif tag == 'triplestore' %}
          bg-lime-100 text-lime-700 hover:bg-lime-200
        {% else %}
          bg-stone-100 text-stone-700 hover:bg-stone-200
        {% endif %}" data-tag="{{ tag }}" aria-pressed="false" aria-label="{{ 'Filter by tag @tag'|t({'@tag': tag}) }}">
        {{ tag|t }}
        <span class="soda-scs-manager--tag-remove" aria-hidden="true">×</span>
      </button>
    {% endfor %}
  </div>
</div>

{% if show_clear_button|default(true) %}
<div class="soda-scs-manager--clear-tag-filters-wrapper flex justify-center">
  <button id="clear-all-tags" type="button" class="soda-scs-manager--clear-tag-filters mx-auto mt-5 flex cursor-pointer items-center justify-center gap-1.5 rounded-full border-2 border-stone-400 bg-white px-5 py-1.5 text-sm font-medium text-stone-800 shadow-sm transition-all hover:bg-stone-50 hover:text-stone-900 hover:shadow-md">
    <span aria-hidden="true" class="font-bold">🗑</span>
    {{ 'Clear all filters'|t }}
    <span aria-hidden="true" class="font-bold">🗑</span>
  </button>
</div>
{% endif %}
{% endif %}
