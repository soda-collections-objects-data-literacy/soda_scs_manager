{#
/**
 * @file
 * Default theme implementation for SODa SCS Manager start page.
 *
 * Two semicircle segments (inner r=30, outer r=90): manager start (/soda-scs-manager/start) left, dashboard right.
 * Center circle and label are drawn last so they appear on top.
 *
 * Optional variables:
 * - intro_coworking_wizard, intro_asset_base, intro_connected_accounts_url: same as dashboard (first-login wizard).
 *
 * @ingroup themeable
 */
#}
<div{{ attributes.addClass('soda-scs-manager--start-page') }}>
  {% if intro_coworking_wizard %}
    {% include '@soda_scs_manager/includes/soda-scs-manager--coworking-intro.html.twig' %}
  {% endif %}
  {# Connect Nextcloud modal - shown when user has not connected Nextcloud (Login Flow v2). #}
  <div class="scs-manager--nextcloud-connect-wrapper">
    <div class="scs-manager--nextcloud-connect-modal hidden fixed inset-0 z-50 flex items-center justify-center bg-black/50" aria-hidden="true" role="dialog" aria-labelledby="nextcloud-connect-title">
      <div class="scs-manager--nextcloud-connect-modal-content bg-white rounded-lg shadow-xl p-6 max-w-md mx-4">
        <h2 id="nextcloud-connect-title" class="text-xl font-semibold mb-4">{{ 'Connect your Nextcloud account'|t }}</h2>
        <p class="text-gray-600 mb-4">{{ 'To use Nextcloud with WissKI and other applications, connect your account once. A popup will open where you log in to Nextcloud. You can also connect later from your <a href=":url">Connected Accounts</a> page.'|t({':url': connected_accounts_url}) }}</p>
        <p class="scs-manager--nextcloud-connect-status hidden mb-2 text-sm"></p>
        <p class="scs-manager--nextcloud-connect-error hidden mb-2 text-sm text-red-600"></p>
        <div class="flex gap-2">
          <button type="button" class="scs-manager--nextcloud-connect-btn px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700">
            {{ 'Connect Nextcloud'|t }}
          </button>
          <button type="button" class="scs-manager--nextcloud-connect-dismiss px-4 py-2 border rounded hover:bg-gray-100">
            {{ 'Later'|t }}
          </button>
        </div>
      </div>
    </div>
  </div>
  <div class="soda-scs-manager--header-section">
    <h1>{{ 'Hi @user!'|t({'@user': user}) }}</h1>
  </div>

  <div class="soda-scs-manager--pie-nav">
    <svg viewBox="0 0 200 200" class="soda-scs-manager--pie-svg">
      <defs>
        {# Clip large enough to include center circle stroke (r=30 + stroke 2 → outer edge ~31). #}
        <clipPath id="soda-scs-manager--pie-center-clip">
          <circle cx="100" cy="100" r="32" />
        </clipPath>
      </defs>

      {# Manager start (/soda-scs-manager/start) — left semicircle. Full-sector hit area. #}
      <a href="{{ path('soda_scs_manager.start_page') }}" class="soda-scs-manager--pie-link" data-pie-label="{{ 'SODa SCS Manager'|t }}">
        <path class="soda-scs-manager--pie-hit" aria-hidden="true" d="M 100 100 L 100 190 A 90 90 0 1 1 100 10 Z" fill="transparent" />
        <g class="soda-scs-manager--pie-segment">
          <path class="soda-scs-manager--pie-slice soda-scs-manager--pie-slice--start"
                d="M 100 190 A 90 90 0 1 1 100 10 L 100 70 A 30 30 0 0 0 70 100 A 30 30 0 0 0 100 130 Z"
                fill="currentColor" />
          <g class="soda-scs-manager--pie-icon" transform="translate(52,88)">
            <svg width="24" height="24" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              {# Same layout icon as sidebar link to this route (SodaScsNavigationBlock). #}
              <path d="M3 4a1 1 0 011-1h12a1 1 0 011 1v2a1 1 0 01-1 1H4a1 1 0 01-1-1V4zM3 10a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H4a1 1 0 01-1-1v-6zM14 9a1 1 0 00-1 1v6a1 1 0 001 1h2a1 1 0 001-1v-6a1 1 0 00-1-1h-2z"/>
            </svg>
          </g>
        </g>
      </a>

      {# Dashboard - right semicircle. Full-sector hit area. #}
      <a href="{{ path('soda_scs_manager.dashboard') }}" class="soda-scs-manager--pie-link" data-pie-label="{{ 'Dashboard'|t }}">
        <path class="soda-scs-manager--pie-hit" aria-hidden="true" d="M 100 100 L 100 10 A 90 90 0 1 1 100 190 Z" fill="transparent" />
        <g class="soda-scs-manager--pie-segment">
          <path class="soda-scs-manager--pie-slice soda-scs-manager--pie-slice--dashboard"
                d="M 100 10 A 90 90 0 1 1 100 190 L 100 130 A 30 30 0 0 1 130 100 A 30 30 0 0 1 100 70 Z"
                fill="currentColor" />
          <g class="soda-scs-manager--pie-icon" transform="translate(124,88)">
            <svg width="24" height="24" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd" d="M3 5a2 2 0 012-2h10a2 2 0 012 2v8a2 2 0 01-2 2h-2.22l.123.489.804.804A1 1 0 0113 18H7a1 1 0 01-.707-1.707l.804-.804L7.22 15H5a2 2 0 01-2-2V5zm5.771 7H5V5h10v7H8.771z" clip-rule="evenodd"></path>
            </svg>
          </g>
        </g>
      </a>

      {# Center circle and label drawn last; text clipped so it does not overflow. #}
      <g clip-path="url(#soda-scs-manager--pie-center-clip)">
        <circle cx="100" cy="100" r="30" class="soda-scs-manager--pie-center" />
        <text x="100" y="100" text-anchor="middle" dominant-baseline="middle" class="soda-scs-manager--pie-center-text" id="soda-scs-manager--pie-center-label" data-pie-default="{{ 'SODa SCS'|t }}">
          <tspan>{{ 'SODa SCS'|t }}</tspan>
        </text>
      </g>
    </svg>
  </div>
</div>
